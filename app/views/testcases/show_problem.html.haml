.container-fluid.py-4
  .d-flex.align-items-center.gap-2.mb-4
    = link_to problems_path, class: 'btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center p-2 rounded-circle shadow-sm', 'data-bs-toggle' => 'tooltip', title: 'Back to Problems' do
      %span.mi.md-18 arrow_back
    %div
      %h2.fw-bold.mb-0 Test Cases
      %p.text-muted.mb-0= @problem.long_name

  .row.g-4
    .col-lg-3
      .card.card-shadow.border-0.h-100
        .card-body.p-4
          %h6.fw-bold.text-uppercase.text-secondary.mb-3.d-flex.align-items-center.gap-2
            %span.mi list
            Test Case Selection
          
          %ul.nav.nav-pills.flex-column.gap-2{role: :tablist}
            - @dataset.testcases.each.with_index do |tc,id|
              %li.nav-item{role: :presentation}
                %a.nav-link.d-flex.justify-content-between.align-items-center.py-2.px-3{href:"#", role: 'tab', data: {bs: {toggle: 'tab', target: "#tc#{tc.id}"}}, class: ('active shadow-sm' if id == 0)}
                  %span.fw-semibold= "Case ##{tc.num}"
                  %span.mi.md-18 chevron_right

          - if @managers.count > 0
            %hr.my-4
            %h6.fw-bold.text-uppercase.text-secondary.mb-3.d-flex.align-items-center.gap-2
              %span.mi description
              Grader Files
            %ul.list-unstyled.small
              - @managers.each do |mg|
                %li.mb-2
                  = link_to download_manager_testcases_path(@problem,mg), class: 'text-decoration-none d-flex align-items-center gap-2' do
                    %span.mi.md-14 attach_file
                    = mg.filename

    .col-lg-9
      .tab-content
        - @dataset.testcases.each.with_index do |tc,id|
          .tab-pane.fade{id: "tc#{tc.id}", class: ('show active' if id == 0)}
            .row.g-4
              .col-md-6
                .card.card-shadow.border-0
                  .card-header.bg-surface-alt.p-3.border-0
                    .d-flex.justify-content-between.align-items-center
                      %h6.fw-bold.mb-0.d-flex.align-items-center.gap-2
                        %span.mi input
                        Input
                      = link_to download_input_testcase_path(tc), class: 'btn btn-sm btn-outline-primary d-flex align-items-center gap-1' do
                        %span.mi.md-14 download
                        Download
                  .card-body.p-0
                    %textarea.form-control.font-monospace.border-0.rounded-0.bg-surface.text-primary{rows: 25, readonly: true, style: "resize: none; font-size: 0.85rem;"}= (tc.inp_file.download.force_encoding('UTF-8') if tc.inp_file.attached?)
              
              .col-md-6
                .card.card-shadow.border-0
                  .card-header.bg-surface-alt.p-3.border-0
                    .d-flex.justify-content-between.align-items-center
                      %h6.fw-bold.mb-0.d-flex.align-items-center.gap-2
                        %span.mi output
                        Output
                      = link_to download_sol_testcase_path(tc), class: 'btn btn-sm btn-outline-primary d-flex align-items-center gap-1' do
                        %span.mi.md-14 download
                        Download
                  .card-body.p-0
                    %textarea.form-control.font-monospace.border-0.rounded-0.bg-surface.text-primary{rows: 25, readonly: true, style: "resize: none; font-size: 0.85rem;"}= (tc.ans_file.download.force_encoding('UTF-8') if tc.ans_file.attached?)
