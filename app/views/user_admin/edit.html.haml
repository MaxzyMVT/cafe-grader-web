= render 'application/breadcrumb', steps: [{ label: 'Users', path: user_admin_index_path, icon: resource_icon_name(User) }, { label: 'Edit' }]

.d-flex.justify-content-between.align-items-center.mb-3
  .d-flex.align-items-center.gap-2
    %h2.fw-bold.text-dark.mb-0
      - if @user.full_name.present?
        = @user.full_name
      - else
        %span.text-muted.fst-italic [User ##{@user.id}]
      %span.font-monospace.text-secondary.fw-normal= "[#{@user.login}]"
    %span.badge.bg-primary-subtle.text-primary.border.border-primary-subtle.rounded-pill.fw-medium
      %small Editing

  .d-flex.gap-2
    = link_to 'Cancel', user_admin_index_path, class: 'btn btn-link text-secondary text-decoration-none'
    %button.btn.btn-primary.px-4.shadow-sm{type: 'submit', form: 'edit_user_form'} Save Changes

.row
  .col-md-5
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Basic Info
        = simple_form_for @user, url: user_admin_path(@user), wrapper: :horizontal_form, html: { id: 'edit_user_form' } do |f|
          = render partial: 'form', locals: {f: f}
  .col-md-7
    .card.shadow-sm.mb-4
      .card-body{data: {controller: 'init-ui-component'}}
        %h5.fw-bold.text-secondary.mb-3 Groups
        %p.small.text-muted.d-flex.align-items-center.gap-1.mb-3
          %span.mi.md-16 info
          Click a group name to navigate there. Add or remove group membership directly.
        - if @user.groups_users.any?
          %table.table.table-sm.align-middle.mb-0
            %thead
              %tr
                %th Group
                %th Description
                %th.text-center Enabled
                %th.text-end Actions
            %tbody
              - @user.groups_users.each do |gu|
                %tr
                  %td= link_to gu.group.name, group_path(gu.group), class: 'text-decoration-none'
                  %td.text-muted= gu.group.description
                  %td.text-center
                    - if gu.group.enabled
                      %span.badge.bg-success-subtle.text-success.border.border-success-subtle Yes
                    - else
                      %span.badge.bg-secondary-subtle.text-secondary.border.border-secondary-subtle No
                  %td.text-end
                    = link_to remove_group_user_admin_path(@user, group_id: gu.group.id), method: :delete, data: { confirm: 'Are you sure you want to remove this user from the group?' }, class: 'btn btn-sm btn-outline-danger' do
                      %span.mi.md-18 delete
        - else
          .text-center.text-muted.py-4
            %span.mi.md-24.d-block.mb-2 group_off
            %p.small.mb-0 Not a member of any group.

        .border-top.pt-3.mt-3
          = form_with url: add_group_user_admin_path(@user), method: :post, class: 'd-flex gap-2 align-items-center' do |f|
            - available_groups = @groups.where.not(id: @user.groups.ids)
            = select_tag :group_id, options_from_collection_for_select(available_groups, :id, :name), include_blank: '-- Select Group --', class: 'select2 form-control form-control-sm', style: 'flex-grow: 1; max-width: 300px;'
            %button.btn.btn-sm.btn-success{type: 'submit'} Add Group

    .card.shadow-sm.mb-4
      .card-body{data: {controller: 'init-ui-component'}}
        %h5.fw-bold.text-secondary.mb-3 Contests
        %p.small.text-muted.d-flex.align-items-center.gap-1.mb-3
          %span.mi.md-16 info
          Click a contest name to navigate there. Add or remove contest enrollment directly.
        - if @user.contests_users.any?
          %table.table.table-sm.align-middle.mb-0
            %thead
              %tr
                %th Contest
                %th Description
                %th.text-center Enabled
                %th.text-end Actions
            %tbody
              - @user.contests_users.each do |cu|
                %tr
                  %td= link_to cu.contest.name, contest_path(cu.contest), class: 'text-decoration-none'
                  %td.text-muted= cu.contest.description
                  %td.text-center
                    - if cu.contest.enabled
                      %span.badge.bg-success-subtle.text-success.border.border-success-subtle Yes
                    - else
                      %span.badge.bg-secondary-subtle.text-secondary.border.border-secondary-subtle No
                  %td.text-end
                    = link_to remove_contest_user_admin_path(@user, contest_id: cu.contest.id), method: :delete, data: { confirm: 'Are you sure you want to remove this user from the contest?' }, class: 'btn btn-sm btn-outline-danger' do
                      %span.mi.md-18 delete
        - else
          .text-center.text-muted.py-4
            %span.mi.md-24.d-block.mb-2 emoji_events
            %p.small.mb-0 Not enrolled in any contest.

        .border-top.pt-3.mt-3
          = form_with url: add_contest_user_admin_path(@user), method: :post, class: 'd-flex gap-2 align-items-center' do |f|
            - available_contests = @contests.where.not(id: @user.contests.ids)
            = select_tag :contest_id, options_from_collection_for_select(available_contests, :id, :name), include_blank: '-- Select Contest --', class: 'select2 form-control form-control-sm', style: 'flex-grow: 1; max-width: 300px;'
            %button.btn.btn-sm.btn-success{type: 'submit'} Add Contest
